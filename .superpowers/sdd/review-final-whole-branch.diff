++        // 0..=13 days ago) — must be dropped entirely, not folded into index 0.
++        let fourteen_days_ago = NOW - 14 * SECONDS_PER_DAY + 100;
++        let buckets = bucket_daily_counts(&[fourteen_days_ago], NOW);
++        assert_eq!(buckets, vec![0; 14]);
