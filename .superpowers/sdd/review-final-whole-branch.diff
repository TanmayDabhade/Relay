++        let thirteen_days_ago = NOW - 13 * SECONDS_PER_DAY + 100;
++
++        let buckets = bucket_daily_counts(&[today, one_day_ago, thirteen_days_ago], NOW);
++
++        let mut expected = vec![0i64; 14];
