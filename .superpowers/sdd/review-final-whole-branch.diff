+      let mut any_finalized = false;
+      for id in &ids {
+        match db::queries::finalize_session(&conn, id) {
+          Ok(()) => any_finalized = true,
+          Err(e) => log::warn!("idle sweep: failed to finalize session {id}: {e:#}"),
+        }
+      }
