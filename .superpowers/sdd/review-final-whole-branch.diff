@@ -45,8 +45,130 @@ pub fn read_new_lines(conn: &Connection, path: &Path) -> anyhow::Result<Vec<Stri
         .and_then(|t| t.duration_since(std::time::UNIX_EPOCH).ok())
         .map(|d| d.as_secs() as i64)
         .unwrap_or(0);
 
