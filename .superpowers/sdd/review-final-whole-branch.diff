++            }
++          }
++        }
++        Err(e) => {
++          log::warn!("idle sweep: summarization API call failed for session {session_id}: {e:#}");
++        }
++      }
++      // `_guard` drops here (or at whichever `return` above fired), removing session_id from
++      // the in-flight set either way.
++    });
++  }
++}
