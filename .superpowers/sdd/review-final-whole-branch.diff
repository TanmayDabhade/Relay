++  for t in totals {
++    let cost = cost::pricing::cost_usd(
++      t.model.as_deref(),
++      t.prompt_tokens,
++      t.completion_tokens,
++      t.cache_read_tokens,
++      t.cache_creation_tokens,
++    );
